rules_version = '2';

// Firebase Storage rules untuk MabarKeun.
// Foto venue & foto profil: dibaca publik; ditulis hanya oleh pemilik (folder = uid-nya).
service firebase.storage {
  match /b/{bucket}/o {
    match /venues/{uid}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
